#!/usr/bin/env bash

set -euo pipefail

open-secure

create-partitions

if [[ -v BOOTSTRAP_ENABLE_LUKS ]]; then
    create-luks
    open-luks
fi

if [[ -v BOOTSTRAP_ENABLE_LVM ]]; then
    create-lvm
    open-lvm
fi

if [[ -v BOOTSTRAP_ENABLE_SWAP ]]; then
    create-swap
    open-swap
fi

create-root
open-root

if [[ -v BOOTSTRAP_ENABLE_LUKS ]]; then
    install-luks-keyfile
fi

if [[ $BOOTSTRAP_BOOT_FIRMWARE == uefi ]]; then
    create-uefi
    open-uefi
fi

close-secure
