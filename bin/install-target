#!/usr/bin/env bash

set -euo pipefail

config-boot
config-initrd

install-packages

if [[ -v BOOTSTRAP_ENABLE_LVM ]]; then
    config-lvm
fi

if [[ -v BOOTSTRAP_ENABLE_TRIM ]]; then
    config-trim
fi

if [[ -v BOOTSTRAP_HOSTNAME ]]; then
    config-hostname
fi

if [[ -v BOOTSTRAP_TIMEZONE ]]; then
    config-timezone
fi

config-locale
config-console
config-network
config-mirrors
config-ntp
config-ssh

if [[ -v BOOTSTRAP_ENABLE_WIRELESS ]]; then
    config-wireless
fi

if [[ -v BOOTSTRAP_ENABLE_ETHERNET ]]; then
    config-ethernet
fi

install-locales
install-fstab
install-boot

config-admin
