#!/usr/bin/env bash

set -euo pipefail

if [[ $BOOTSTRAP_FS_ROOT_KIND == btrfs && -v BOOTSTRAP_FS_ROOT_ENABLE_SUBVOLUMES ]]; then
    while read -r name path; do
        mount --verbose --mkdir \
            -o "${BOOTSTRAP_FS_ROOT_OPTIONS:+$BOOTSTRAP_FS_ROOT_OPTIONS,}subvol=$name" \
            "$BOOTSTRAP_ROOT_DEVICE" "$BOOTSTRAP_TARGET_MOUNT_DIR/${path#/}"
    done <"$BOOTSTRAP_CONFIG_DIR"/file_systems/"$BOOTSTRAP_FS_ROOT_KIND"/root/subvolumes
else
    mount --verbose --mkdir \
        ${BOOTSTRAP_FS_ROOT_OPTIONS:+--options "$BOOTSTRAP_FS_ROOT_OPTIONS"} \
        "$BOOTSTRAP_ROOT_DEVICE" "$BOOTSTRAP_TARGET_MOUNT_DIR"
fi
